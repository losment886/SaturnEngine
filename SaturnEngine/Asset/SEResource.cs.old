    [StructLayout(LayoutKind.Sequential)]
    public struct TIME
    {
        public ushort YEAR;
        public byte MONTH;
        public byte DAY;
        public byte HOUR;
        public byte MINUTE;
        public byte SECOND;
        public byte MILLISECOND;
        public TIME(ulong CAT)
        {
            DataLayout dl = new DataLayout();
            dl.UL = CAT;
            YEAR = dl.US0;
            MONTH = dl.B2;
            DAY = dl.B3;
            HOUR = dl.B4;
            MINUTE = dl.B5;
            SECOND = dl.B6;
            MILLISECOND = dl.B7;
        }
        public TIME(DateTime DT)
        {
            YEAR = (ushort)DT.Year;
            MONTH = (byte)DT.Month;
            DAY = (byte)DT.Day;
            HOUR = (byte)DT.Hour;
            MINUTE = (byte)DT.Minute;
            SECOND = (byte)DT.Second;
            MILLISECOND = (byte)DT.Millisecond;
        }
        public DateTime GetDateTime()
        {
            try
            {
                return new DateTime(YEAR, MONTH, DAY, HOUR, MINUTE, SECOND, MILLISECOND);
            }
            catch
            {
                return new DateTime();
            }
        }
        public ulong GetTimeCode()
        {
            DataLayout dl = new DataLayout();
            dl.US0 = YEAR;
            dl.B2 = MONTH;
            dl.B3 = DAY;
            dl.B4 = HOUR;
            dl.B5 = MINUTE;
            dl.B6 = SECOND;
            dl.B7 = MILLISECOND;
            return dl.UL;
        }
    }
    public struct VERSION
    {
        public byte Major;
        public byte Minor;
        public byte Build;
        public byte Revision;


        public VERSION(Version v)
        {
            Major = (byte)v.Major;
            Minor = (byte)v.Minor;
            Build = (byte)v.Build;
            Revision = (byte)v.Revision;
        }
        public VERSION(uint v)
        {
            DataLayout dl = new DataLayout();
            dl.UI0 = v;
            Major = dl.B0;
            Minor = dl.B1;
            Build = dl.B2;
            Revision = dl.B3;
        }

        public Version GetVersion()
        {
            return new Version(Major, Minor, Build, Revision);
        }

        public uint GetVersionCode()
        {
            DataLayout dl = new DataLayout();

            dl.B0 = Major;
            dl.B1 = Minor;
            dl.B2 = Build;
            dl.B3 = Revision;
            return dl.UI0;
        }

    }
    public unsafe class SERBlock
    {
        public SEResource Father;
        public ulong StartIndex;//blokstart
        public ulong NAMESTC;
        public TIME Time;
        public ushort Type;
        public ushort Flag;//default=0,lock=1
        public ulong PasswordSTCSTC;
        public uint crc32;

        public FILE thisFile;

        public MemoryStream Context;
    }
    //SE包文件
    //默认后缀为*.spk
    //不限制后缀
    //define
    /* [HEAD]
     * SESF(4b) VER(4b=>0x00 0x00 0x00 0x01==("0.0.0.1") => struct VERSION) DATETIME(8B => struct TIME)
     * DEVELOPSTC  FLG4b BOKCOU4b       CRC32CODE4b
     * [END]（36B）
     * 
     * [PACKAGE]
     * SEPK（4B）
     * NAMESTC TIME  TYP2b  FLG2b  PASSSTCSTC8b  CRC32
     * LENGTH
     * DATA(4B)
     * [END]（48B）
     * 
     * TIP:
     * block lock=>
     * if i%2=>b+B0-B2
     * if i%3=>b+B1-B3
     * if i%5=>b+B4-B6
     * if i%7=>b+B5-B7
     */
    [Obsolete("Use LRL instead of this")]
    public class SEResource
    {
        public enum SERFLG : uint
        {
            Empty = 0,

            FEATURE_Support = 1,

            FEETURE_AllowOverBlock = 2,
            FEATURE_AllowCrossFile = 4,
            FEATURE_AllowStreaming = 8,
            FEATURE_Compress = 16
        }

        public const string Ext = ".spk";
        public string FilePath;
        public MemoryStream MainStream;
        public VERSION Version;
        public TIME Time;
        public ulong DeveloperSTC;
        public SERFLG Flag;
        public uint CRC32CODE;
        public uint BlockCount;



        public SERBlock[] Blocks;

        public bool NewFile;

        public uint AddNewBlock(string bname, bool locked = false, string password = "")
        {
            if (BlockCount > 1)
            {
                SERBlock sb = new SERBlock();
                sb.NAMESTC = STCCode.GetSTC(bname);
                ulong psi = 0;
                psi = (ulong)Blocks[BlockCount - 1].StartIndex + Blocks[BlockCount - 1].thisFile.Length + 48ul;
                sb.StartIndex = psi;
                sb.Father = this;
                sb.Flag = 0;
                sb.Time = new TIME(DateTime.Now);
                sb.PasswordSTCSTC = 0;
                MemoryStream ms = new MemoryStream();
                if (locked)
                {
                    sb.Flag = 1;
                    sb.PasswordSTCSTC = STCCode.GetSTC(password);

                }
                sb.Context = ms;
                Blocks = Blocks.Append(sb).ToArray();
                BlockCount++;
                return (uint)Blocks.LongLength - 1;
            }
            else
            {
                SERBlock sb = new SERBlock();
                sb.NAMESTC = STCCode.GetSTC(bname);
                ulong psi = 0;
                psi = (ulong)36 + 48ul;
                sb.StartIndex = psi;
                sb.Father = this;
                sb.Flag = 0;
                sb.Time = new TIME(DateTime.Now);
                sb.PasswordSTCSTC = 0;
                MemoryStream ms = new MemoryStream();
                if (locked)
                {
                    sb.Flag = 1;
                    sb.PasswordSTCSTC = STCCode.GetSTC(password);

                }
                sb.Context = ms;
                Blocks = Blocks.Append(sb).ToArray();
                BlockCount++;
                return (uint)Blocks.LongLength - 1;
            }
        }

        public uint AddNewBlock(ulong bname_stc, bool locked = false, string password = "")
        {
            if (BlockCount > 1)
            {
                SERBlock sb = new SERBlock();
                sb.NAMESTC = (bname_stc);
                ulong psi = 0;
                psi = (ulong)Blocks[BlockCount - 1].StartIndex + Blocks[BlockCount - 1].thisFile.Length + 48ul;
                sb.StartIndex = psi;
                sb.Father = this;
                sb.Flag = 0;
                sb.Time = new TIME(DateTime.Now);
                sb.PasswordSTCSTC = 0;
