                if (locked)
                {
                    sb.Flag = 1;
                    sb.PasswordSTCSTC = STCCode.GetSTC(password);

                }
                sb.Context = ms;
                Blocks = Blocks.Append(sb).ToArray();
                BlockCount++;
                return (uint)Blocks.LongLength - 1;
            }
            else
            {
                SERBlock sb = new SERBlock();
