<Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LRLPackager.Views.AddFileView">
    <Grid Grid.Row="1" Margin="5">
      <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <!-- 导入名 -->
      <TextBlock Text="导入名 (nullable):" Grid.Row="0" Grid.Column="0" 
                 VerticalAlignment="Center" Margin="0 0 10 10" FontWeight="Medium"/>
      <TextBox Name="NameBox" Text="" Grid.Row="0" Grid.Column="1"  Grid.ColumnSpan="3"
               Margin="0 0 0 10" />
      <!-- 密码框 -->
      <TextBlock Text="密码    (nullable):" Grid.Row="1" Grid.Column="0" 
                 VerticalAlignment="Center" Margin="0 0 10 10" FontWeight="Medium"/>
      <TextBox Name="PassBox" Text="" Grid.Row="1" Grid.Column="1"  Grid.ColumnSpan="3"
               Margin="0 0 0 10" />
      <!-- 是否加密 -->
      <TextBlock Text="是否加密:" Grid.Row="2" Grid.Column="0" 
                 VerticalAlignment="Center" Margin="0 0 10 10" FontWeight="Medium"/>
      <CheckBox Name="CheckerE" IsChecked="" Grid.Row="2" Grid.Column="1" 
                Margin="0 0 0 10" VerticalAlignment="Center"/>
      <!-- 是否加密 -->
      <TextBlock Text="是否压缩:" Grid.Row="2" Grid.Column="2" 
                 VerticalAlignment="Center" Margin="0 0 10 10" FontWeight="Medium"/>
      <CheckBox Name="CheckerC" IsChecked="" Grid.Row="2" Grid.Column="3" 
                Margin="0 0 0 10" VerticalAlignment="Center"/>
      <Button Name="EnterButton" Grid.Column="3" Grid.Row="3" Content="确定" Click="EnterButton_OnClick"></Button>
      <Button Name="CancelButton" Grid.Column="2" Grid.Row="3" Content="取消" Click="CancelButton_OnClick"></Button>
  </Grid>
</Window>
